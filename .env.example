# ═══════════════════════════════════════════
# BOT TELEGRAM NIK VALIDATOR - Configuration
# ═══════════════════════════════════════════

# Telegram Bot Token (dari @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Owner Settings (Telegram User ID, comma separated untuk multi-owner)
OWNER_ID=123456789

# API Settings - CekNIK (itsrose.art)
API_KEY=FireFart
API_BASE_URL=https://api.itsrose.art/v1/ceknik

# EYEX API (untuk /nama dan /kk) - LEGACY
EYEX_API_KEY=your_eyex_key
EYEX_BASE_URL=https://api.eyex.dev

# Archi3 Identity API (untuk /ceknik, /nama, /kk)
ARCHI3_API_KEY=your_archi3_key
ARCHI3_BASE_URL=https://api.archi3.dev/identity

# STARKILLER API (untuk /foto)
STARKILLER_API_KEY=your_starkiller_key
STARKILLER_BASE_URL=https://starkiller.space/api/v1

# EDABU API (untuk /edabu - BPJS)
EDABU_API_KEY=your_edabu_key
EDABU_BASE_URL=http://164.92.180.153:2006/api

# BPJSTK API (untuk /bpjstk - BPJS Ketenagakerjaan)
# API: http://38.49.208.151:3540/api/search
BPJSTK_API_KEY=your_bpjstk_api_key

# ASEX Vehicle API (untuk /nopol, /noka, /nosin, /nikplat) - APIv3
ASEX_API_KEY=your_asex_api_key

# TerbangBebas API (untuk /nopol, /noka, /nosin, /nikvehicle)
TERBANGBEBAS_API_KEY=your_terbangbebas_api_key

# NOPOL API (untuk /nopol - Legacy)
NOPOL_API_KEY=your_nopol_key
NOPOL_BASE_URL=https://siakses.my.id/api

# NIKFOTO API Key (ASEX cid2full - untuk /nikfoto dan /niklengkap)
NIKFOTO_API_KEY=your_nikfoto_api_key

# NAMA2 API Key (ASEX Name2Data - untuk /nama2)
NAMA2_API_KEY=your_nama2_api_key

# LeakOSINT API (untuk /databocor)
LEAKOSINT_API_URL=https://leakosintapi.com/
LEAKOSINT_TOKEN=your_leakosint_token

# GetContact API (untuk /getcontact)
GETCONTACT_API_URL=https://data-publik.com/api/getcontact/multisource
GETCONTACT_KEY=your_getcontact_key

# Watermark Settings
WATERMARK_TEXT=CONFIDENTIAL
SET_WATERMARK=true

# Midtrans Payment Gateway (QRIS Only)
MIDTRANS_SERVER_KEY=Mid-server-xxxxx
MIDTRANS_CLIENT_KEY=Mid-client-xxxxx
MIDTRANS_MERCHANT_ID=G000000000

# Token Settings
TOKEN_PRICE=5000
MIN_TOPUP_TOKEN=10
CHECK_COST=2
CHECKV2_COST=2

# Cost per feature (dalam token)
NAMA_COST=3
NAMA2_COST=3
KK_COST=3
KKV2_COST=3
CEKNOMOR_COST=3
CEKNOMORV2_COST=3
FOTO_COST=5
EDABU_COST=3
EDABUMASSAL_COST=3
BPJSTK_COST=3
NOPOL_COST=3
NOKA_COST=3
NOSIN_COST=3
NIKPLAT_COST=3
NIKFOTO_COST=5
NIKLENGKAP_COST=8
DATABOCOR_COST=3
GETCONTACT_COST=3
BUGWA_COST=3
RIWAYAT_COST=0
GETDATA_COST=0.5
RIWAYAT_DAYS=10

# BugWA API
BUGWA_BASE_URL=http://159.223.64.52:5004
BUGWA_SESSION_USER=your_bugwa_session_user
BUGWA_SESSION_ID=your_bugwa_session_id

# Bot Settings
BOT_NAME=NIK Validator Bot
PREFIX=/
